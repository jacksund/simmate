{
  "context": {
    "fileName": "ai_assistants.md",
    "includeDirectories": [
      "docs/full_guides/contributing"
    ]
  },
  "experimental": {
    "plan": true,
    "modelSteering": true
  },
  "general": {
    "defaultApprovalMode": "auto_edit"
  },
  "ui": {
    "showStatusInTitle": true,
    "hideTips": true,
    "footer": {
      "hideSandboxStatus": true,
      "hideContextPercentage": false
    },
    "loadingPhrases": "witty"
  },
  "security": {
    "enablePermanentToolApproval": true,
    "toolAllowlist": [
       "ls",
       "mkdir",
       "cd",
       "pwd",
       "cat",
       "grep",
       "touch",
       "mv",
       "git status",
       "git commit",
       "git diff",
       "git add"
    ]
  }
}
